# --- Bedrock ---
# Model is pinned and config-driven. Sonnet 4.5 because it still accepts
# temperature=0 and is the FedRAMP-High-authorized model in GovCloud.
# Do NOT swap to a 4.6+/5 model without removing every temperature=0.
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-20250929
AWS_REGION=us-east-1

# --- AWS credentials ---
# Come from the standard AWS credential chain / IAM role. No keys in code.
# For local dev only, you may set them here (leave blank to use the chain):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# --- Database ---
# Inside docker compose the host is `postgres`; for local (non-Docker) runs use `localhost`.
DATABASE_URL=postgresql+psycopg://airtight:airtight@localhost:5432/airtight
