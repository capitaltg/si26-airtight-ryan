{
  "name": "airtight-e2e",
  "version": "0.1.0",
  "private": true,
  "description": "End-to-end smoke tests driving the running Airtight stack with Playwright.",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "install:browsers": "playwright install --with-deps chromium",
    "stack:up": "docker compose -f ../docker-compose.yml up -d --build",
    "stack:wait": "wait-on -t 120000 http-get://localhost:8000/health http-get://localhost:5173",
    "stack:down": "docker compose -f ../docker-compose.yml down -v",
    "e2e": "npm run stack:up && npm run stack:wait && sh -c 'npx playwright test; ec=$?; npm run stack:down; exit $ec'"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.48.0",
    "wait-on": "^8.0.1"
  }
}
